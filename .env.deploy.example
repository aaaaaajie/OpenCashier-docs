# Host port used by the docs site. Pick any free high port.
DOCS_PORT=3001

# Use 0.0.0.0 for direct public access, or 127.0.0.1 when an existing
# Nginx/Caddy/Traefik on the same server will reverse proxy to this app.
DOCS_HOST_BIND=0.0.0.0

IMAGE_NAME=opencashier-docs
IMAGE_TAG=local
CONTAINER_NAME=opencashier-docs
COMPOSE_PROJECT_NAME=opencashier-docs
